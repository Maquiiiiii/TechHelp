# ==============================================================================
# TechHelp Backend — Variables de Entorno para PRODUCCIÓN (Railway)
# ==============================================================================
# ⚠️  NUNCA subas este archivo a Git. Está en .gitignore.
# Copia estos valores en Railway → tu servicio backend → pestaña Variables
# ==============================================================================

# -----------------------------------------------
# MongoDB — Railway provee esta variable automáticamente.
# En Railway usa la sintaxis de referencia:  ${{MongoDB.MONGO_URL}}
# Railway la resuelve internamente a la URL privada del servicio MongoDB.
# -----------------------------------------------
MONGO_URI=${{MongoDB.MONGO_URL}}

# -----------------------------------------------
# JWT — Clave secreta (usa algo largo y aleatorio, mínimo 32 caracteres)
# -----------------------------------------------
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_ALEATORIA_EN_PRODUCCION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------
# CORS — URL exacta del frontend en Netlify (sin barra final)
# -----------------------------------------------
CORS_ORIGINS=https://techhelp-security.netlify.app

# -----------------------------------------------
# Frontend URL — Para links generados en logs de emails simulados
# -----------------------------------------------
FRONTEND_URL=https://techhelp-security.netlify.app

# ==============================================================================
# TechHelp Backend — Variables de Entorno para DESARROLLO LOCAL (Docker)
# ==============================================================================
# Copia estas variables en backend/.env para desarrollo local
# Asegúrate de que Docker esté corriendo: docker compose -f docker-compose.dev.yml up -d
# ==============================================================================

# MONGO_URI=mongodb://techhelp_user:techhelp_pass@localhost:27017/techhelp_db?authSource=admin
# JWT_SECRET=clave_local_de_desarrollo
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# CORS_ORIGINS=http://localhost:5173
# FRONTEND_URL=http://localhost:5173
