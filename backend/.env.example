# ==============================================================================
# TechHelp Backend — Variables de Entorno para PRODUCCIÓN (Railway)
# ==============================================================================
# ⚠️  NUNCA subas este archivo a Git. Está en .gitignore.
# Copia estos valores en Railway → tu servicio → Variables
# ==============================================================================

# -----------------------------------------------
# MongoDB Atlas — Cadena de conexión completa
# -----------------------------------------------
# Reemplaza <usuario>, <password> y <cluster> con los valores de tu Atlas
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/techhelp_db?retryWrites=true&w=majority

# -----------------------------------------------
# JWT — Clave secreta (cámbiala por algo largo y aleatorio)
# -----------------------------------------------
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_Y_ALEATORIA_EN_PRODUCCION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------
# CORS — Orígenes permitidos
# Pon aquí la URL exacta de tu frontend en Netlify (sin barra final)
# Si tienes más de un origen sepáralos con coma
# -----------------------------------------------
CORS_ORIGINS=https://techhelp-security.netlify.app

# -----------------------------------------------
# Frontend URL — Para links generados en emails y logs
# -----------------------------------------------
FRONTEND_URL=https://techhelp-security.netlify.app

# -----------------------------------------------
# Entorno
# -----------------------------------------------
NODE_ENV=production
